# Secrets for the Limn container (referenced from limn.yaml as ${VAR}).

# Demo mode: no token, rate-limited, non-storing. Remove (or set 0) to run
# a private instance instead — then read the generated access token from
# `docker compose logs limn`.
LIMN_DEMO=1

# Self-hosted SwarmUI behind auth:
SWARMUI_TOKEN=changeme

# Cloud providers, if limn.yaml uses them:
# GEMINI_API_KEY=
# OPENAI_API_KEY=
